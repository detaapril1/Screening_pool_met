# ============================================================================
# METEORA POOL SCREENING BOT - CONFIGURATION FILE
# ============================================================================
# Copy this file to .env and fill in your actual API keys and settings
# 
# IMPORTANT: Never commit your .env file with real API keys to GitHub!
# Keep it private and secure.
# ============================================================================


# ============================================================================
# REQUIRED API KEYS (Must be set before running)
# ============================================================================

# Solscan API Key
# Get from: https://solscan.io/
# Free account gives you access to their API
# You need to sign up and get your API key
SOLSCAN_API_KEY=your_solscan_api_key_here

# Telegram Bot Token
# Get from: https://t.me/BotFather
# Steps:
#   1. Open Telegram and search for @BotFather
#   2. Send /start
#   3. Send /newbot
#   4. Choose a name and username for your bot
#   5. Copy the token provided
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID
# Where the bot will send notifications
# Can be:
#   - Your personal Telegram ID (DM with bot)
#   - A group chat ID
#   - A channel ID
# To find your ID: Send /start to @userinfobot in Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ============================================================================
# PROGRAM IDs (Default values provided, change only if needed)
# ============================================================================

# Meteora Program ID (official)
# Leave as is unless you know what you're doing
METEORA_PROGRAM_ID=Eo7WjKq67rjm34Z9o5KvymzZH3DLmycq5hash5LvZQJ

# Raydium Program ID (alternative DEX)
# Leave as is unless you want to include Raydium pools
RAYDIUM_PROGRAM_ID=675kPX9MHTjS2zt1qrXjVnYYtYUZsqBoWQe8J7RETiX


# ============================================================================
# SCREENING CRITERIA - Customize pool selection
# ============================================================================

# Minimum liquidity in USD
# Only pools with at least this much liquidity are considered "good"
# Recommended: $5,000 - $50,000
# Default: 10000
MIN_LIQUIDITY_USD=10000

# Minimum 24h trading volume in USD
# Pool must have active trading to be good
# Recommended: $2,000 - $10,000
# Default: 5000
MIN_VOLUME_24H_USD=5000

# Minimum pool score (0-100)
# Higher = stricter filtering
# Score based on: liquidity, volume, fees, age, token quality, safety
# Recommended: 60-80
# Default: 70
MIN_POOL_SCORE=70

# Maximum pool age in hours
# Only consider pools created within this many hours
# 720 hours = 30 days
# 168 hours = 7 days
# 24 hours = 1 day
# Recommended: 168-720 (1-4 weeks)
# Default: 720
MAX_AGE_HOURS=720

# Minimum fee tier (%)
# Liquidity providers need incentive to supply liquidity
# Recommended: 0.01-0.1
# Default: 0.01
MIN_FEE_TIER=0.01

# Maximum fee tier (%)
# Fees shouldn't be too high for traders
# Recommended: 0.5-2.0
# Default: 1.0
MAX_FEE_TIER=1.0


# ============================================================================
# BOT BEHAVIOR - Adjust how often bot checks and notifies
# ============================================================================

# Seconds between each screening cycle
# Shorter = more frequent checks (higher API usage)
# 300 = 5 minutes
# 600 = 10 minutes
# 1800 = 30 minutes
# Recommended: 300-600
# Default: 300
SCREENING_INTERVAL=300

# Number of pools to fetch per API request
# Higher = fewer API calls but more data per call
# Recommended: 50-200
# Default: 100
SOLSCAN_BATCH_SIZE=100

# Enable debug mode for verbose logging
# Set to 'True' to see more detailed logs
# Default: False
DEBUG_MODE=False


# ============================================================================
# FILTERING OPTIONS - Choose what pools to include
# ============================================================================

# Filter pools by token type
# Options: 'spl', 'wsol', 'usdc', 'all'
# 'all' = no token type filtering
# Default: all
FILTER_BY_TOKEN_TYPE=all

# Exclude pools with known rug pull patterns
# Set to 'False' to disable this check
# Default: True
EXCLUDE_RUG_PULL_TOKENS=True

# Exclude pools with honeypot token patterns
# Honeypots: tokens that can't be sold after buying
# Default: True
EXCLUDE_HONEYPOT_TOKENS=True

# Only include pools with verified tokens
# Verified tokens are checked by Solscan
# Set to 'True' for more conservative filtering
# Default: False
REQUIRE_VERIFIED_TOKENS=False


# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================

# Send test message when bot starts
# Useful to verify Telegram integration is working
# Set to 'False' to disable
# Default: True
SEND_TEST_MESSAGE=True

# Notify on ALL pools checked (for debugging)
# If 'True', you'll get notifications for every pool
# If 'False', only "good" pools get notified
# Recommended: False (to avoid spam)
# Default: False
NOTIFY_ON_ALL_POOLS=False


# ============================================================================
# OPTIONAL - MONITORING AND LOGGING
# ============================================================================

# Log file location
# Where bot activity logs are saved
# Default: bot.log
LOG_FILE=bot.log

# Log level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommended: INFO
LOG_LEVEL=INFO


# ============================================================================
# OPTIONAL - DATABASE STORAGE
# ============================================================================

# If you want to store pool data in a database
# Uncomment and configure for PostgreSQL

# DATABASE_URL=postgresql://user:password@localhost:5432/meteora_pools
# Enable database storage: false
# ENABLE_DATABASE_STORAGE=false


# ============================================================================
# OPTIONAL - WEB DASHBOARD
# ============================================================================

# If you want to run a web dashboard to view pools
# Uncomment and configure

# ENABLE_WEB_DASHBOARD=false
# WEB_DASHBOARD_PORT=8000
# WEB_DASHBOARD_HOST=0.0.0.0


# ============================================================================
# OPTIONAL - MONITORING METRICS
# ============================================================================

# Enable Prometheus metrics for monitoring
# ENABLE_PROMETHEUS=false
# PROMETHEUS_PORT=9090
